<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.22"/>
  <object class="GtkWindow" id="main_window">
    <property name="default-width">360</property>
    <property name="default-height">140</property>
    <property name="title">Gestament GTK4 Fixture</property>
    <property name="child">
      <object class="GtkBox" id="main_box">
        <property name="margin-start">16</property>
        <property name="margin-end">16</property>
        <property name="margin-top">16</property>
        <property name="margin-bottom">16</property>
        <property name="orientation">vertical</property>
        <property name="spacing">12</property>
        <child>
          <object class="GtkEntry" id="name_entry"/>
        </child>
        <child>
          <object class="GtkButton" id="submit_button">
            <property name="label">Submit</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="result_label">
            <property name="label"></property>
            <property name="xalign">0</property>
          </object>
        </child>
      </object>
    </property>
  </object>
  <object class="GtkAdjustment" id="spin_adjustment">
    <property name="lower">0</property>
    <property name="upper">10</property>
    <property name="value">2</property>
    <property name="step-increment">1</property>
    <property name="page-increment">5</property>
  </object>
  <object class="GtkAdjustment" id="slider_adjustment">
    <property name="lower">0</property>
    <property name="upper">100</property>
    <property name="value">25</property>
    <property name="step-increment">5</property>
    <property name="page-increment">10</property>
  </object>
  <object class="GtkAdjustment" id="standard_scrollbar_adjustment">
    <property name="lower">0</property>
    <property name="upper">100</property>
    <property name="value">20</property>
    <property name="step-increment">5</property>
    <property name="page-increment">10</property>
  </object>
  <object class="GtkWindow" id="controls_window">
    <property name="default-width">360</property>
    <property name="default-height">640</property>
    <property name="title">Gestament GTK4 Controls</property>
    <property name="child">
      <object class="GtkBox" id="controls_box">
        <property name="margin-start">16</property>
        <property name="margin-end">16</property>
        <property name="margin-top">16</property>
        <property name="margin-bottom">16</property>
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <child>
          <object class="GtkCheckButton" id="check_control">
            <property name="label">Check control</property>
          </object>
        </child>
        <child>
          <object class="GtkSwitch" id="switch_control">
            <property name="active">False</property>
            <property name="halign">start</property>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="radio_a_control">
            <property name="label">Radio A</property>
            <property name="active">True</property>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="radio_b_control">
            <property name="label">Radio B</property>
            <property name="group">radio_a_control</property>
          </object>
        </child>
        <child>
          <object class="GtkToggleButton" id="toggle_button_control">
            <property name="label">Toggle control</property>
          </object>
        </child>
        <child>
          <object class="GtkSpinButton" id="spin_button_control">
            <property name="adjustment">spin_adjustment</property>
            <property name="numeric">True</property>
          </object>
        </child>
        <child>
          <object class="GtkScale" id="slider_control">
            <property name="orientation">horizontal</property>
            <property name="adjustment">slider_adjustment</property>
            <property name="digits">0</property>
            <property name="draw-value">True</property>
          </object>
        </child>
        <child>
          <object class="GtkProgressBar" id="progress_bar_control">
            <property name="fraction">0.4</property>
            <property name="show-text">True</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="input_probe">
            <property name="label">Input probe</property>
            <property name="focusable">True</property>
            <property name="width-request">300</property>
            <property name="height-request">40</property>
          </object>
        </child>
        <child>
          <object class="GtkImage" id="image_control">
            <property name="halign">start</property>
            <property name="valign">start</property>
          </object>
        </child>
      </object>
    </property>
  </object>
  <object class="GtkWindow" id="standards_window">
    <property name="default-width">520</property>
    <property name="default-height">720</property>
    <property name="title">Gestament GTK4 Standards</property>
    <property name="child">
      <object class="GtkBox" id="standards_box">
        <property name="margin-start">16</property>
        <property name="margin-end">16</property>
        <property name="margin-top">16</property>
        <property name="margin-bottom">16</property>
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <child>
          <object class="GtkNotebook" id="standard_notebook">
            <child>
              <object class="GtkNotebookPage">
                <property name="child">
                  <object class="GtkLabel" id="standard_notebook_panel_a">
                    <property name="label">Notebook Page A</property>
                  </object>
                </property>
                <property name="tab">
                  <object class="GtkLabel">
                    <property name="label">Notebook A</property>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkNotebookPage">
                <property name="child">
                  <object class="GtkLabel" id="standard_notebook_panel_b">
                    <property name="label">Notebook Page B</property>
                  </object>
                </property>
                <property name="tab">
                  <object class="GtkLabel">
                    <property name="label">Notebook B</property>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="standard_stack_box">
            <property name="orientation">vertical</property>
            <property name="spacing">4</property>
            <child>
              <object class="GtkStackSwitcher" id="standard_stack_switcher">
                <property name="stack">standard_stack</property>
              </object>
            </child>
            <child>
              <object class="GtkStack" id="standard_stack">
                <child>
                  <object class="GtkStackPage">
                    <property name="name">stack-a</property>
                    <property name="title">Stack A</property>
                    <property name="child">
                      <object class="GtkLabel" id="standard_stack_panel_a">
                        <property name="label">Stack Page A</property>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="GtkStackPage">
                    <property name="name">stack-b</property>
                    <property name="title">Stack B</property>
                    <property name="child">
                      <object class="GtkLabel" id="standard_stack_panel_b">
                        <property name="label">Stack Page B</property>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkExpander" id="standard_expander">
            <property name="label">More options</property>
            <property name="child">
              <object class="GtkLabel" id="standard_expander_child">
                <property name="label">Expanded content</property>
              </object>
            </property>
          </object>
        </child>
        <child>
          <object class="GtkScrollbar" id="standard_scrollbar">
            <property name="orientation">horizontal</property>
            <property name="adjustment">standard_scrollbar_adjustment</property>
            <property name="width-request">260</property>
            <property name="height-request">24</property>
          </object>
        </child>
        <child>
          <object class="GtkLinkButton" id="standard_link">
            <property name="uri">https://example.invalid</property>
            <property name="label">Example Link</property>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="standard_separator_area">
            <property name="orientation">vertical</property>
            <property name="height-request">24</property>
            <child>
              <object class="GtkSeparator" id="standard_separator">
                <property name="orientation">horizontal</property>
                <property name="valign">center</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkCalendar" id="standard_calendar"/>
        </child>
      </object>
    </property>
  </object>
</interface>
